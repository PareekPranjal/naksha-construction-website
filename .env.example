# Local development (used by `next dev`)
# Copy to .env.local
NEXT_PUBLIC_API_URL=http://localhost:4000

# Production (committed in .env.production)
# NEXT_PUBLIC_API_URL=https://naksha-ct-backend-production.up.railway.app

# On-demand revalidation — when the backend POSTs to /api/revalidate, the secret
# in its Authorization: Bearer header must match this value. Leave empty to
# accept unauthenticated revalidate requests (not recommended in production).
# Set the SAME value on the backend (Railway env var REVALIDATE_SECRET).
REVALIDATE_SECRET=
